# Redis
EKKO_REDIS_HOST=127.0.0.1
EKKO_REDIS_PASSWORD=
EKKO_REDIS_PORT=6379
EKKO_REDIS_DB=0

# Database
EKKO_DATABASE_URL=mysql+aiomysql://username:password@127.0.0.1:3306/ekko?charset=utf8mb4
EKKO_DB_ECHO=False
EKKO_DB_POOL_SIZE=10
EKKO_DB_MAX_OVERFLOW=20

# Mail
EKKO_MAIL_USERNAME=your_email@example.com
EKKO_MAIL_PASSWORD=your_mail_authorization_code
EKKO_MAIL_FROM=your_email@example.com
EKKO_MAIL_PORT=587
EKKO_MAIL_SERVER=smtp.example.com

# Verify Code
EKKO_VERIFY_CODE_LENGTH=6
EKKO_VERIFY_EXPIRE_TIME=120

# LiveKit
EKKO_LIVEKIT_INTERNAL_URL=ws://127.0.0.1:7880
EKKO_LIVEKIT_PUBLIC_URL=ws://127.0.0.1:7880
EKKO_LIVEKIT_API_KEY=your_livekit_api_key
EKKO_LIVEKIT_API_SECRET=your_livekit_api_secret
EKKO_LIVEKIT_TOKEN_EXPIRE_SECONDS=3600

# Audio event filter between server-side VAD and ASR (YAMNet)
EKKO_AUDIO_EVENT_ENABLED=true
EKKO_AUDIO_EVENT_REMOTE_URL=http://127.0.0.1:19003/audio-events/classify
EKKO_AUDIO_EVENT_REMOTE_TOKEN=
EKKO_AUDIO_EVENT_REMOTE_TIMEOUT_SECONDS=15
EKKO_AUDIO_EVENT_REMOTE_TOP_K=8
EKKO_AUDIO_EVENT_ENFORCE_FILTER=true
EKKO_AUDIO_EVENT_MIN_SPEECH_SCORE=0.8

# Voice message transcription (ASR)
EKKO_ASR_LANGUAGE=zh
EKKO_ASR_REMOTE_URL=http://127.0.0.1:9000/asr/transcribe
EKKO_ASR_REMOTE_TOKEN=
EKKO_ASR_REMOTE_TIMEOUT_SECONDS=30

# Voice excitement scoring weights
EKKO_VOICE_EXCITEMENT_AMPLITUDE_WEIGHT=0.5
EKKO_VOICE_EXCITEMENT_CHAR_RATE_WEIGHT=0.3
EKKO_VOICE_EXCITEMENT_PEAK_RATE_WEIGHT=0.2

# Judge / channel analysis remote service
# When ekko calls ekko_judge_service locally, point to http://127.0.0.1:19002/analyze
# EKKO_ANALYSIS_REMOTE_TOKEN must match ekko_judge_service's EKKO_JUDGE_SERVICE_TOKEN
EKKO_ANALYSIS_REMOTE_URL=http://127.0.0.1:19002/analyze
EKKO_ANALYSIS_REMOTE_TOKEN=ekko-local-judge-token
EKKO_ANALYSIS_REMOTE_TIMEOUT_SECONDS=120
EKKO_ANALYSIS_MAX_MESSAGES=80
EKKO_ANALYSIS_MAX_CHARS=20000
